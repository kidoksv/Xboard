[Unit]
Description=Xboard node WebSocket server
After=network.target redis-server.service mysql.service
Wants=redis-server.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/xboard/current
Environment=APP_ENV=production
ExecStart=/usr/bin/php artisan ws-server start --host=127.0.0.1 --port=8076
Restart=always
RestartSec=5
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
